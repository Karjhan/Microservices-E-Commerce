{
  "Jwt": {
    "Secret": "super-secret-key-that-never-be-found-out-in-this-life",
    "Issuer": "auth-service",
    "Audience": "ecommerce"
  },

  "Services": {
    "Auth": "http://localhost:5132",
    "Catalog": "http://localhost:5134"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-public": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },

      "catalog-products": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/products/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://localhost:5132"
          }
        }
      },

      "catalog-cluster": {
        "Destinations": {
          "catalog": {
            "Address": "http://localhost:5134"
          }
        }
      }
    }
  },

  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317"
}