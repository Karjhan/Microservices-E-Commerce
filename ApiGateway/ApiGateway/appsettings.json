{
  "Jwt": {
    "Secret": "super-secret-key-that-never-be-found-out-in-this-life",
    "Issuer": "auth-service",
    "Audience": "ecommerce"
  },

  "Services": {
    "Auth": "http://auth:8080",
    "Catalog": "http://catalog:8080",
    "Payments": "http://payments:8080",
    "Graphrag": "http://payments:8080"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-public": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },

      "catalog-products": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/products/{**catch-all}"
        }
      },

      "payments": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/payments/{**catch-all}"
        }
      },

      "graphrag-search": {
        "ClusterId": "graphrag-cluster",
        "Match": {
          "Path": "/graphrag/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/graphrag" }
        ]
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://auth:8080"
          }
        }
      },

      "catalog-cluster": {
        "Destinations": {
          "catalog": {
            "Address": "http://catalog:8080"
          }
        }
      },

      "payments-cluster": {
        "Destinations": {
          "payments": {
            "Address": "http://payments:8080"
          }
        }
      },

      "graphrag-cluster": {
        "Destinations": {
          "graphrag": {
            "Address": "http://graphrag-api:8100"
          }
        }
      }
    }
  },

  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://jaeger:4317"
}